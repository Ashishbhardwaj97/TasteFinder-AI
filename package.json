{
  "name": "zomato-recommendation-service",
  "version": "1.0.0",
  "type": "module",
  "description": "AI-Powered Restaurant Recommendation System",
  "main": "src/server.js",
  "scripts": {
    "ingest": "node ingest.js",
    "start": "node src/server.js",
    "test:ingest": "node tests/ingest.test.js",
    "test:filter": "node tests/filter.test.js",
    "test:llm": "node tests/llm.test.js",
    "test:server": "node tests/server.test.js",
    "test": "node tests/ingest.test.js && node tests/filter.test.js && node tests/server.test.js",
    "dev:client": "vite",
    "build:client": "vite build",
    "dev": "concurrently \"npm run start\" \"npm run dev:client\""
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "vite": "^5.3.1"
  }
}
