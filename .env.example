# ==============================================================================
# AI-Powered Zomato Restaurant Recommendation System Configuration Example
# ==============================================================================
# Copy this file to '.env' and fill in your credentials.
# e.g., cp .env.example .env (or copy-paste manually)
#
# MODERN NODE.JS TIP:
# Starting with Node.js v20.6.0, you do not need 'dotenv' library! You can load
# this file natively by running: node --env-file=.env src/server.js
# ==============================================================================

# Server Configuration
PORT=3000

# LLM Orchestrator Config (groq)
LLM_PROVIDER=groq

# Groq Cloud API Configuration
# Get your API key at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
